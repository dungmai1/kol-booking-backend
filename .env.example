# Database (Supabase Postgres)
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# Spring Profiles
SPRING_PROFILES_ACTIVE=

# Mail Configuration (Optional - for production)
SPRING_MAIL_HOST=
SPRING_MAIL_PORT=
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
APP_URL=
APP_JWT_SECRET=
APP_CORS_ALLOWED_ORIGINS=
# Java Options
JAVA_OPTS=-Xmx512m -Xms256m

APP_FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:8081

# VNPay sandbox (https://sandbox.vnpayment.vn/). Leave blank to disable VNPay in dev.
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# Must point to backend return handler (redirects browser to APP_FRONTEND_URL/payment/result).
VNPAY_RETURN_URL=http://localhost:8081/api/v1/payments/vnpay/return
# Register IPN URL in VNPay merchant portal: http://localhost:8081/api/v1/payments/vnpay/ipn
PAYMENT_MOCK_SECRET=

